# HuggingFace Hub write token
# 발급: https://huggingface.co/settings/tokens (Type=Write 필수)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WandB API key (학습 시각화 — 선택)
# 발급: https://wandb.ai/authorize (가입 후 web 토큰 복사)
# 환경변수로 잡히면 'wandb login' 실행 불요 — wandb 가 자동 인식
WANDB_API_KEY=wandb_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
