# smolVLA 프로젝트 gitignore

# ── venv (노드별) ──────────────────────────────────────────────────────────────
orin/.hylion_arm/
dgx/.arm_finetune/

# ── Python 공통 ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── IDE / 에디터 ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 기타 런타임 생성 파일 ──────────────────────────────────────────────────────
*.log
.DS_Store

# ── 환경변수 / 비밀 ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
