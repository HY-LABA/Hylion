{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hylion.local/schemas/smolvla_session.schema.json",
  "title": "SmolVLA Session Schema (Minimal)",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "created_at"],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "operator": {
      "type": "string"
    },
    "control_mode": {
      "type": "string",
      "enum": ["teleop", "scripted", "assist"]
    },
    "notes": {
      "type": "string"
    }
  }
}