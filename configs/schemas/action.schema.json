{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HYlion Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "timestamp",
    "session_id",
    "source",
    "network_online",
    "intent",
    "target_object",
    "reply_text",
    "requires_smolvla",
    "requires_bhl",
    "gait_cmd",
    "state_current",
    "safety_allowed",
    "fallback_policy"
  ],
  "properties": {
    "action_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "enum": ["terminal", "mic"] },
    "network_online": { "type": "boolean" },
    "intent": { "type": "string", "enum": ["chat", "pick_place", "move", "stop", "unknown"] },
    "target_object": { "type": "string" },
    "reply_text": { "type": "string", "minLength": 1 },
    "requires_smolvla": { "type": "boolean" },
    "requires_bhl": { "type": "boolean" },
    "gait_cmd": { "type": "string", "enum": ["walk_forward", "turn_left", "stop", "none"] },
    "state_current": { "type": "string", "enum": ["IDLE", "TALKING", "MANIPULATING", "WALKING", "EMERGENCY"] },
    "safety_allowed": { "type": "boolean" },
    "fallback_policy": { "type": "string" }
  }
}
